// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRoleName {
  DIRECTION
  ASSISTANTE_ADMINISTRATIVE
  CONDUCTEUR_TRAVAUX
  CHEF_CHANTIER
}

enum ProjectStatus {
  PREPARATION
  PLANIFICATION
  DEMARRAGE
  REALISATION
  RECEPTION
  CLOTURE
}

enum IssueStatus {
  OUVERTE
  EN_COURS
  LEVEE
}

enum IssuePriority {
  FAIBLE
  MOYENNE
  HAUTE
  CRITIQUE
}

enum PhotoCategory {
  AVANT_TRAVAUX
  PENDANT_TRAVAUX
  APRES_TRAVAUX
}

enum AlertType {
  RETARD_CHANTIER
  RESERVE_CRITIQUE
  BUDGET_80
  BUDGET_100
}

enum ResourceType {
  MAIN_OEUVRE
  MATERIEL
  SOUS_TRAITANT
  AUTRE
}

enum ExpenseCategory {
  ACHAT_MATERIAUX
  LOCATION
  SOUS_TRAITANCE
  MAIN_OEUVRE
  FRAIS_GENERAUX
  AUTRE
}

enum ExpenseStatus {
  DRAFT
  VALIDATED
  CANCELLED
}

enum AlertStatus {
  ACTIVE
  TRAITEE
}

enum ScheduleStatus {
  PLANNED
  CONFIRMED
  CANCELLED
}

model Role {
  id          String @id @default(uuid())
  name        UserRoleName @unique
  description String?
  users       User[]
}

model User {
  id            String    @id @default(uuid())
  firstName     String
  lastName      String
  email         String    @unique
  passwordHash  String
  isActive      Boolean   @default(true)
  roleId        String
  role          Role      @relation(fields: [roleId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  assignments      Assignment[]
  ownedProjects    Project[] @relation("ProjectConductor")
  createdIssues    Issue[]   @relation("IssueCreator")
  assignedIssues   Issue[]   @relation("IssueAssignee")
  photosCreated    Photo[]   @relation("PhotoAuthor")
  workerProfile    Worker?
  schedulesCreated WorkerSchedule[] @relation("ScheduleCreator")
  resourcesCreated ProjectResource[] @relation("ResourceCreator")
  expensesCreated  ProjectExpense[]  @relation("ExpenseCreator")
}

model Project {
  id              String        @id @default(uuid())
  reference       String        @unique
  name            String
  client          String
  address         String
  budget           Decimal?  @db.Decimal(14, 2)
  budgetAlertAt80  Boolean   @default(true)
  budgetAlertAt100 Boolean   @default(true)
  startDate       DateTime
  expectedEndDate DateTime
  receptionDate   DateTime?
  status          ProjectStatus @default(PREPARATION)
  conductorId     String
  conductor       User          @relation("ProjectConductor", fields: [conductorId], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  assignments     Assignment[]
  issues          Issue[]
  photos          Photo[]
  progress        ProgressUpdate[]
  alerts          Alert[]
  history         HistoryEvent[]
  workerSchedules WorkerSchedule[]
  resources       ProjectResource[]
  expenses        ProjectExpense[]
}

model ProjectResource {
  id           String       @id @default(uuid())
  projectId    String
  type         ResourceType
  label        String
  unitCost     Decimal      @db.Decimal(12, 2)
  quantity     Decimal      @db.Decimal(10, 2) @default(1)
  totalPlanned Decimal      @db.Decimal(14, 2)
  notes        String?
  createdById  String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User    @relation("ResourceCreator", fields: [createdById], references: [id])

  @@index([projectId])
}

model ProjectExpense {
  id               String          @id @default(uuid())
  projectId        String
  category         ExpenseCategory
  label            String
  amount           Decimal         @db.Decimal(12, 2)
  expenseDate      DateTime        @db.Date
  supplier         String?
  invoiceReference String?
  attachmentUrl    String?
  status           ExpenseStatus   @default(VALIDATED)
  notes            String?
  createdById      String
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User    @relation("ExpenseCreator", fields: [createdById], references: [id])

  @@index([projectId, expenseDate])
  @@index([projectId, status])
}

model Worker {
  id          String   @id @default(uuid())
  firstName   String
  lastName    String
  trade       String?
  hourlyRate  Decimal? @db.Decimal(10, 2)
  dailyRate   Decimal? @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  userId      String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User?    @relation(fields: [userId], references: [id])
  schedules   WorkerSchedule[]

  @@index([isActive])
  @@index([lastName, firstName])
}

model WorkerSchedule {
  id          String         @id @default(uuid())
  workerId    String
  projectId   String
  startAt     DateTime
  endAt       DateTime
  status      ScheduleStatus @default(PLANNED)
  notes       String?
  createdById String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  worker      Worker         @relation(fields: [workerId], references: [id])
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy   User           @relation("ScheduleCreator", fields: [createdById], references: [id])

  @@index([workerId, startAt, endAt])
  @@index([projectId, startAt])
  @@index([startAt, endAt])
}

model Assignment {
  id             String   @id @default(uuid())
  projectId      String
  userId         String
  functionLabel  String
  assignmentDate DateTime @default(now())
  isActive       Boolean  @default(true)
  project        Project  @relation(fields: [projectId], references: [id])
  user           User     @relation(fields: [userId], references: [id])
}

model Issue {
  id            String        @id @default(uuid())
  projectId     String
  title         String
  description   String
  priority      IssuePriority
  status        IssueStatus   @default(OUVERTE)
  createdById   String
  assignedToId  String?
  closedById    String?
  createdAt     DateTime      @default(now())
  takenAt       DateTime?
  closedAt      DateTime?
  project       Project       @relation(fields: [projectId], references: [id])
  createdBy     User          @relation("IssueCreator", fields: [createdById], references: [id])
  assignedTo    User?         @relation("IssueAssignee", fields: [assignedToId], references: [id])
}

model Photo {
  id               String        @id @default(uuid())
  projectId        String
  fileName         String
  originalFileName String
  fileUrl          String
  storageKey       String        @unique
  mimeType         String
  fileSizeBytes    Int
  category         PhotoCategory
  comment          String?
  addedById        String
  deletedAt        DateTime?
  deletedById      String?
  createdAt        DateTime      @default(now())
  project          Project       @relation(fields: [projectId], references: [id])
  addedBy          User          @relation("PhotoAuthor", fields: [addedById], references: [id])

  @@index([projectId, deletedAt])
  @@index([projectId, category])
}

model ProgressUpdate {
  id            String   @id @default(uuid())
  projectId     String
  authorId      String
  comment       String
  progressRatio Int?
  createdAt     DateTime @default(now())
  project       Project  @relation(fields: [projectId], references: [id])
}

model Alert {
  id          String      @id @default(uuid())
  projectId   String
  type        AlertType
  message     String
  status      AlertStatus @default(ACTIVE)
  createdAt   DateTime    @default(now())
  processedAt DateTime?
  project     Project     @relation(fields: [projectId], references: [id])
}

model HistoryEvent {
  id         String   @id @default(uuid())
  projectId  String
  userId     String
  action     String
  oldValue   String?
  newValue   String?
  reason     String?
  createdAt  DateTime @default(now())
  project    Project  @relation(fields: [projectId], references: [id])
}

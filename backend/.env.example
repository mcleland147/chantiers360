DATABASE_URL=postgresql://chantiers360:chantiers360@postgres:5432/chantiers360?schema=public
# Obligatoire — min. 32 caractères, mélange lettres/chiffres (démarrage refusé sinon)
JWT_SECRET=replace-with-strong-secret-at-least-32-chars
JWT_EXPIRES_IN=15m
# Origines CORS autorisées (séparées par des virgules)
CORS_ORIGIN=http://localhost:5173
PORT=3000
# NODE_ENV=production désactive Swagger (sauf ENABLE_SWAGGER=true)
NODE_ENV=development

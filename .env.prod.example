# Chantiers360 — variables production / REC locale
# Copier : cp .env.prod.example .env.prod

NODE_ENV=production

# --- PostgreSQL (réseau Docker internal uniquement) ---
POSTGRES_DB=chantiers360
POSTGRES_USER=chantiers360
POSTGRES_PASSWORD=change-me-strong-postgres-password-32chars

# --- JWT (obligatoire, ≥ 32 caractères, hors liste interdite) ---
JWT_SECRET=change-me-local-prod-jwt-secret-minimum-32-characters
JWT_EXPIRES_IN=15m

# --- CORS (origine publique du frontend) ---
CORS_ORIGIN=https://localhost

# --- Frontend build (Vite — figé au build Docker) ---
# URL relative recommandée : même origine via Caddy /api
VITE_API_BASE_URL=/api

# --- Caddy / TLS ---
APP_DOMAIN=localhost
# Local : certificat auto Caddy. VPS : laisser vide et configurer ACME (voir guide)
TLS_BLOCK=tls internal
# VPS Let's Encrypt :
# TLS_BLOCK=
# CADDY_GLOBAL_OPTIONS=email admin@votredomaine.fr

CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# Seed demo REC locale (après premier up) :
# docker compose -f docker-compose.prod.yml --env-file .env.prod --profile seed run --rm seed
